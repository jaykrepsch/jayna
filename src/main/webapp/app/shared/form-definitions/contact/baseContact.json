{
  "_comment": "Standard-Abschnitte für alle Kontakt-Form-Definitionen. Diese werden in spezifischen Kontakt-Definitionen referenziert.",
  "general": {
    "title": "jaynaApp.baseContact.general.title",
    "fields": [
      {
        "name": "label",
        "type": "text",
        "rules": "required"
      },
      {
        "name": "description",
        "type": "text"
      },
      {
        "name": "entityState",
        "type": "dropdown",
        "boxLabel": "global.menu.choose",
        "enumName": "entityState",
        "defaultValue": "ACTIVE"
      }
    ]
  },
  "personalData": {
    "title": "jaynaApp.baseContact.personalData.title",
    "fields": [
      {
        "name": "title",
        "type": "dropdown",
        "boxLabel": "global.menu.choose",
        "enumName": "title"
      },
      {
        "name": "salutation",
        "type": "dropdown",
        "boxLabel": "global.menu.choose",
        "enumName": "salutation"
      },
      {
        "name": "rank",
        "type": "dropdown",
        "boxLabel": "global.menu.choose",
        "enumName": "rank"
      },
      {
        "name": "firstName",
        "type": "text"
      },
      {
        "name": "otherFirstNames",
        "type": "text"
      },
      {
        "name": "surName",
        "type": "text"
      },
      {
        "name": "birthName",
        "type": "text"
      },
      {
        "name": "nickName",
        "type": "text"
      },
      {
        "name": "birthDate",
        "type": "date",
        "enableTimePicker": false,
        "autoApply": true,
        "textInput": true,
        "format": "dd.MM.yyyy"
      },
      {
        "name": "birthCity",
        "type": "text"
      },
      {
        "name": "birthCountry",
        "type": "text"
      },
      {
        "name": "nationality",
        "type": "text"
      },
      {
        "name": "gender",
        "type": "dropdown",
        "boxLabel": "global.menu.choose",
        "enumName": "gender"
      },
      {
        "name": "maritalStatus",
        "type": "dropdown",
        "boxLabel": "global.menu.choose",
        "enumName": "maritalStatus"
      }
    ]
  },
  "contactData": {
    "title": "jaynaApp.baseContact.contactData.title",
    "fields": [
      {
        "name": "communicationType",
        "type": "dropdown",
        "boxLabel": "global.menu.choose",
        "enumName": "communicationType"
      },
      {
        "name": "phoneCountryCode",
        "type": "number"
      },
      {
        "name": "phonePrefix",
        "type": "number"
      },
      {
        "name": "phoneNumber",
        "type": "number"
      }
    ]
  },
  "address": {
    "title": "jaynaApp.baseContact.address.title",
    "fields": [
      {
        "name": "addressType",
        "type": "dropdown",
        "boxLabel": "global.menu.choose",
        "enumName": "addressType"
      },
      {
        "name": "street",
        "type": "text"
      },
      {
        "name": "streetNumber",
        "type": "text"
      },
      {
        "name": "postalCode",
        "type": "text"
      },
      {
        "name": "city",
        "type": "text"
      },
      {
        "name": "additionalAddressField1",
        "type": "text"
      },
      {
        "name": "additionalAddressField2",
        "type": "text"
      }
    ]
  },
  "weiteres": {
    "title": "jaynaApp.baseContact.weiteres.title",
    "fields": [
      {
        "name": "comment",
        "type": "textarea"
      },
      {
        "name": "notes",
        "type": "textarea"
      }
    ]
  },
  "relations": {
    "title": "jaynaApp.baseContact.relations.title"
  },
  "organisation": {
    "title": "jaynaApp.baseContract.organisation.title",
    "fields": [
      {
        "name": "organisationTable",
        "type": "organisation-table",
        "label": "Kalender, Aufgaben & Notizen"
      }
    ]
  },
  "documents": {
    "title": "jaynaApp.baseContract.documents.title",
    "fields": [
      {
        "name": "documentsTable",
        "type": "documents-table",
        "label": "Verknüpfte Dokumente"
      }
    ]
  }
}
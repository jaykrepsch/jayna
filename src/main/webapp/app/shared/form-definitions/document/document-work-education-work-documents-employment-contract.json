            },
            {
              "value": "hourly",
              "label": "Stündlich"
            },
            {
              "value": "yearly",
              "label": "Jährlich"
            }
          ],
          "default": "monthly"
        },
        {
          "name": "workingHours",
          "type": "number",
          "step": "0.5",
          "min": "0",
          "max": "168"
        },
        {
          "name": "position",
          "type": "text",
          "required": true
        },
        {
          "name": "department",
          "type": "text"
        },
        {
          "name": "workplace",
          "type": "text"
        },
        {
          "name": "contractType",
          "type": "select",
          "options": [
            {
              "value": "permanent",
              "label": "Unbefristet"
            },
            {
              "value": "fixed-term",
              "label": "Befristet"
            },
            {
              "value": "temporary",
              "label": "Zeitarbeit"
            },
            {
              "value": "part-time",
              "label": "Teilzeit"
            },
            {
              "value": "full-time",
              "label": "Vollzeit"
            }
          ],
          "default": "permanent"

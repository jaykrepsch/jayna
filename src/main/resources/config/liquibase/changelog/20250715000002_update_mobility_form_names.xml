    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="20250715000002-1" author="jayna">
        <comment>Aktualisiere alle Mobility Form-Namen basierend auf dem Contract-Employment-Employee-TerminationAgreement-Konzept</comment>
        
        <!-- Auto (Car) -->
        <update tableName="group_type">
            <column name="form_name" value="mobility-passengervehicle-car-car"/>
            <where>name = 'Auto' AND entity_name = 'mobility'</where>
        </update>
        

<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <changeSet id="20230227_load_properties" author="jhipster">
        <loadData
                  file="config/liquibase/data/category_properties.csv"
                  separator=";"
                  tableName="category"
                  usePreparedStatements="true">
            <column name="id" type="numeric"/>
        </loadData>
        <loadData
                  file="config/liquibase/data/sub_category_properties.csv"
                  separator=";"
                  tableName="sub_category"
                  usePreparedStatements="true">
            <column name="id" type="numeric"/>
        </loadData>
        <loadData
                  file="config/liquibase/data/sub_category_group_properties.csv"
                  separator=";"
                  tableName="sub_category_group"
                  usePreparedStatements="true">
            <column name="id" type="numeric"/>
        </loadData>
        <loadData
                  file="config/liquibase/data/group_type_properties.csv"
                  separator=";"
                  tableName="group_type"
                  usePreparedStatements="true">
            <column name="id" type="numeric"/>
        </loadData>
    </changeSet>

</databaseChangeLog>
